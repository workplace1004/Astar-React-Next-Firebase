# API – backend base URL (NestJS)
VITE_API_URL=http://localhost:3000

# Mercado Pago — clave pública para el formulario de tarjeta (Bricks). Debe ser la de la MISMA aplicación que MERCADOPAGO_ACCESS_TOKEN del backend.
# Si ves "secure_fields_card_token_creation_failed": clave test/prod mezclada, o cuenta de prueba sin rol comprador/vendedor en el panel MP.
# Si en producción (Vercel) el navegador muestra CORS en POST .../v1/card_tokens: en Mercado Pago Developers
# → Tu integración → [tu aplicación] → agregá la URL del sitio (ej. https://tu-app.vercel.app) en URLs/dominios permitidos del checkout / integración web.
# Sin eso, la API puede responder al preflight sin Access-Control-Allow-Origin y el Brick falla.
VITE_MERCADOPAGO_PUBLIC_KEY=TEST-1323600008746462-040610-dc983fb70bd077f3714bebc5649e90dc-1500342819

# PayPal — client id para Smart Buttons (misma aplicación que PAYPAL_CLIENT_ID en el backend)
# VITE_PAYPAL_CLIENT_ID=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend (optional, for running the NestJS server)
# PORT=3000
# JWT_SECRET=your-secret-change-in-production
