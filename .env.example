# API – backend base URL (NestJS)
VITE_API_URL=http://localhost:3000

# Mercado Pago — solo la CLAVE PÚBLICA (Checkout Bricks). NO pongas el Access Token aquí.
# En prueba suele verse como TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (UUID).
# Debe ser de la MISMA aplicación que MERCADOPAGO_ACCESS_TOKEN en el backend (mismo panel → Credenciales).
# Si ves "secure_fields_card_token_creation_failed": (1) clave y token de apps distintas o test/prod mezclados,
# (2) falta agregar https://tu-dominio en URLs permitidas en Mercado Pago (CORS en .../card_tokens),
# (3) extensión del navegador / bloqueo de terceros.
VITE_MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# PayPal — client id para Smart Buttons (misma aplicación que PAYPAL_CLIENT_ID en el backend)
# VITE_PAYPAL_CLIENT_ID=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend (optional, for running the NestJS server)
# PORT=3000
# JWT_SECRET=your-secret-change-in-production
